# Rust
/target/
**/*.rs.bk
Cargo.lock.bak

# Gradle / Android
.gradle/
build/
**/build/
*.iml
local.properties
captures/
.externalNativeBuild/
.cxx/

# IntelliJ / Android Studio
.idea/
*.ipr
*.iws

# OS junk
.DS_Store
Thumbs.db

# Editor temp
*.swp
*.swo

# Compiled native libraries that get regenerated by build_rust.sh
# (kept tracked when checked-in deliberately)
# app/src/main/jniLibs/

# Paparazzi failures (regenerate on next CI run)
app/build/paparazzi/failures/

# Release signing — keystore + base64-encoded copy must NEVER be
# committed. The release workflow decodes RELEASE_KEYSTORE_BASE64
# (a GitHub Secret) into RUNNER_TEMP at job time; locally you'd
# generate qubee-release.jks once and keep it outside the repo.
*.jks
*.jks.b64
*.keystore
keystore.properties

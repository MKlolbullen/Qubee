<?xml version="1.0" encoding="utf-8"?>
<navigation xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/nav_graph"
    app:startDestination="@id/navigation_conversations">

    <fragment
        android:id="@+id/navigation_conversations"
        android:name="com.qubee.messenger.ui.main.ConversationsFragment"
        android:label="Chats"
        tools:layout="@layout/fragment_conversations">
        <action
            android:id="@+id/action_to_chat"
            app:destination="@id/chatFragment" />
        <action
            android:id="@+id/action_to_contact_selection"
            app:destination="@id/contactSelectionFragment" />
        <action
            android:id="@+id/action_to_group_invite"
            app:destination="@id/groupInviteFragment" />
    </fragment>

    <fragment
        android:id="@+id/navigation_contacts"
        android:name="com.qubee.messenger.ui.contacts.ContactsFragment"
        android:label="Contacts"
        tools:layout="@layout/fragment_contacts">
        <action
            android:id="@+id/action_contact_to_chat"
            app:destination="@id/chatFragment" />
        <action
            android:id="@+id/action_contact_to_add_contact"
            app:destination="@id/addContactFragment" />
    </fragment>

    <fragment
        android:id="@+id/navigation_settings"
        android:name="com.qubee.messenger.ui.settings.SettingsFragment"
        android:label="Settings" />

    <fragment
        android:id="@+id/chatFragment"
        android:name="com.qubee.messenger.ui.chat.ChatFragment"
        android:label="Chat">
        <argument
            android:name="contactId"
            app:argType="string" />
    </fragment>

    <fragment
        android:id="@+id/contactSelectionFragment"
        android:name="com.qubee.messenger.ui.contacts.ContactSelectionFragment"
        android:label="Choose contact" />

    <!-- Group invite / scan flow. Optionally pre-populated with a deep
         link via the `inviteLink` argument (set by MainActivity when
         the user opens a qubee://invite/... URI). -->
    <fragment
        android:id="@+id/groupInviteFragment"
        android:name="com.qubee.messenger.ui.groups.GroupInviteFragment"
        android:label="Group invite">
        <argument
            android:name="inviteLink"
            app:argType="string"
            app:nullable="true"
            android:defaultValue="@null" />
        <deepLink app:uri="qubee://invite/{token}" />
    </fragment>

    <!-- Adding a contact from a scanned/pasted qubee://identity/... link. -->
    <fragment
        android:id="@+id/addContactFragment"
        android:name="com.qubee.messenger.ui.contacts.AddContactFragment"
        android:label="Add contact">
        <argument
            android:name="identityLink"
            app:argType="string"
            app:nullable="true"
            android:defaultValue="@null" />
        <deepLink app:uri="qubee://identity/{token}" />
    </fragment>

</navigation>
